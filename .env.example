# GEMINI_API_KEY: Required server-side for the /api/chat proxy.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# GROQ_API_KEY: Required server-side for the /api/groq proxy.
# Get a key at https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"

# GOOGLE_CLIENT_ID: Required for Google One Tap sign-in (client-side, public).
# Create credentials at https://console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0 Client IDs.
# Choose "Web application", add your domain to Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"
